<UserControl x:Class="WorkToolbox.TcpMonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hc="https://handyorg.github.io/handycontrol">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <hc:Card hc:BorderElement.CornerRadius="10" Background="White" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal" Margin="15">
                <hc:TextBox x:Name="TargetIpInput" 
                            hc:InfoElement.Title="远程目标 (IP:端口)" 
                            hc:InfoElement.Placeholder="192.168.1.1:5000"
                            Text="127.0.0.1:5000" 
                            Width="250" Margin="0,0,10,0"/>

                <Button Content="添加监控" Click="AddTarget_Click" 
                        Style="{StaticResource ButtonPrimary}" VerticalAlignment="Bottom" Height="35" Width="80"/>

                <Button Content="清空列表" Click="Clear_Click" 
                        Style="{StaticResource ButtonDefault}" VerticalAlignment="Bottom" Height="35" Width="80" Margin="10,0,0,0"/>

                <TextBlock x:Name="MonitorStatus" Text="监控中..." Visibility="Collapsed"
                           VerticalAlignment="Bottom" Margin="20,0,0,8" Foreground="Green"/>
            </StackPanel>
        </hc:Card>

        <hc:Card Grid.Row="1" hc:BorderElement.CornerRadius="10" Background="White">
            <DataGrid x:Name="MonitorDataGrid" AutoGenerateColumns="False" IsReadOnly="True" 
                      HeadersVisibility="Column" RowHeaderWidth="0" BorderThickness="0" Margin="10">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="目标地址" Binding="{Binding Target}" Width="150"/>

                    <DataGridTemplateColumn Header="端口状态" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="10" Height="10" Fill="{Binding PortStatusColor}" Margin="0,0,5,0"/>
                                    <TextBlock Text="{Binding PortStatusText}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="延迟 (ms)" Binding="{Binding Latency}" Width="100"/>

                    <DataGridTemplateColumn Header="丢包率" Width="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <ProgressBar Value="{Binding LossRate, Mode=OneWay}" 
             Maximum="100" 
             Height="10" 
             Foreground="{Binding LossColor, Mode=OneWay}"/>
                                    <TextBlock Text="{Binding LossRateText}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10"/>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="已发/丢失" Binding="{Binding StatDetail}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </hc:Card>
    </Grid>
</UserControl>